<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===================================================== -->
    <!--                  TABITEM STYLE                        -->
    <!-- ===================================================== -->

    <Style x:Key="DefaultTabItemStyle" TargetType="TabItem">

        <!-- APARÊNCIA -->
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="Background" Value="{DynamicResource BackgroundPanelBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="FontFamily" Value="{DynamicResource FontFamilyDefault}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeNormal}" />

        <!-- TEMPLATE -->
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Grid>
                        <!-- LINHA SUPERIOR DA ABA -->
                        <Border x:Name="TopBorder"
                                Background="Transparent"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0,3,0,0"
                                CornerRadius="5,5,0,0"
                                Margin="0,2,0,0"
                                Padding="{TemplateBinding Padding}"
                                Panel.ZIndex="1">
                        </Border>
                        <!-- CORPO DA ABA -->
                        <Border x:Name="TabBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1,2,1,0"
                            CornerRadius="5,5,0,0"
                            Margin="0,2,0,0"
                            Padding="{TemplateBinding Padding}">
                            <ContentPresenter
                                x:Name="HeaderContent"
                                ContentSource="Header"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                    

                    <!-- TRIGGERS -->
                    <ControlTemplate.Triggers>
                        <!-- HOVER -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource PrimaryHoverBrush}" />
                        </Trigger>

                        <!-- SELECTED -->
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource BackgroundCardBrush}" />
                            <Setter TargetName="TopBorder" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                            <Setter TargetName="HeaderContent" Property="TextElement.FontWeight" Value="SemiBold" />
                        </Trigger>

                        <!-- DISABLED -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.6" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <!-- ===================================================== -->
    <!--                TABCONTROL STYLE                       -->
    <!-- ===================================================== -->

    <Style x:Key="DefaultTabControlStyle" TargetType="TabControl">
        <!-- APARÊNCIA -->
        <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="0" />

        <!-- TEMPLATE -->
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabControl">
                    <Grid ClipToBounds="True">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- CABEÇALHO DAS ABAS -->
                        <TabPanel Grid.Row="0"
                                  Background="Transparent"
                                  IsItemsHost="True"
                                  Margin="0,0,0,-1"
                                  Panel.ZIndex="2" />

                        <!-- CONTEÚDO -->
                        <Border Grid.Row="1"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0,0,5,5"
                                Padding="5">
                            <ContentPresenter x:Name="PART_SelectedContentHost" ContentSource="SelectedContent" />
                        </Border>
                        
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>