<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===================================================== -->
    <!--                 LOADING SPINNER STYLE                 -->
    <!-- ===================================================== -->

    <Style x:Key="LoadingSpinnerStyle" TargetType="Ellipse">

        <Setter Property="Width" Value="48" />
        <Setter Property="Height" Value="48" />
        <Setter Property="Margin" Value="10" />
        <Setter Property="StrokeThickness" Value="4" />
        <Setter Property="Stroke" Value="{DynamicResource PrimaryHoverBrush}" />
        <Setter Property="StrokeDashArray" Value="6 6" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="RenderTransform">
            <Setter.Value>
                <RotateTransform />
            </Setter.Value>
        </Setter>
       
        <!-- ANIMAÇÃO -->
        <Style.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever">
                        <DoubleAnimation
                            Storyboard.TargetProperty="RenderTransform.Angle"
                            From="0"
                            To="360"
                            Duration="0:0:3" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>


    <!-- ===================================================== -->
    <!--                 LOADING OVERLAY STYLE                 -->
    <!-- ===================================================== -->

    <Style x:Key="LoadingOverlayStyle" TargetType="Border">
        <Setter Property="Background" Value="#10000000" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="CornerRadius" Value="5" />
        <Setter Property="Padding" Value="10" />
    </Style>

</ResourceDictionary>