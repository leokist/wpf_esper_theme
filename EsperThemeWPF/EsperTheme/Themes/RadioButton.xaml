<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===================================================== -->
    <!--               DEFAULT RADIOBUTTON STYLE               -->
    <!-- ===================================================== -->

    <Style x:Key="RadioButtonDefaultStyle"
           TargetType="RadioButton">

        <!-- APARÊNCIA -->
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1.5" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Margin" Value="2" />

        <!-- TIPOGRAFIA -->
        <Setter Property="FontFamily" Value="{DynamicResource FontFamilyDefault}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeNormal}" />

        <!-- TEMPLATE -->
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- RADIO -->
                        <Grid Width="18"
                              Height="18"
                              VerticalAlignment="Center">

                            <!-- CÍRCULO EXTERNO -->
                            <Border x:Name="OuterCircle"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="9" />

                            <!-- CÍRCULO INTERNO -->
                            <Border x:Name="InnerCircle"
                                    Width="10"
                                    Height="10"
                                    Background="{DynamicResource PrimaryBrush}"
                                    CornerRadius="5"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Visibility="Collapsed" />
                        </Grid>

                        <!-- TEXTO -->
                        <ContentPresenter
                            Grid.Column="1"
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            RecognizesAccessKey="True" />
                    </Grid>

                    <!-- TRIGGERS -->
                    <ControlTemplate.Triggers>

                        <!-- HOVER -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="OuterCircle" Property="BorderBrush" Value="{DynamicResource PrimaryHoverBrush}" />
                        </Trigger>

                        <!-- CHECKED -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="OuterCircle" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                            <Setter TargetName="OuterCircle" Property="BorderThickness" Value="2" />
                            <Setter TargetName="InnerCircle" Property="Visibility" Value="Visible" />
                        </Trigger>

                        <!-- DISABLED -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.6" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>