<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ========================================================= -->
    <!--                    DEFAULT TEXTBOX STYLE                  -->
    <!-- ========================================================= -->
    <Style x:Key="TextBoxBaseStyle" TargetType="TextBox">

        <!-- ===================================================== -->
        <!--                     APARÊNCIA                          -->
        <!-- ===================================================== -->

        <Setter Property="Background" Value="{DynamicResource BackgroundCardBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="5,2,5,2" />
        <Setter Property="CaretBrush" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="MinHeight" Value="25" />
        <Setter Property="VerticalContentAlignment" Value="Center" />

        <!-- ===================================================== -->
        <!--                     TIPOGRAFIA                         -->
        <!-- ===================================================== -->

        <Setter Property="FontFamily" Value="{DynamicResource  FontFamilyDefault}" />
        <Setter Property="FontSize" Value="{DynamicResource  FontSizeNormal}" />

        <!-- ===================================================== -->
        <!--                     TEMPLATE                           -->
        <!-- ===================================================== -->

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border
                        x:Name="TextBoxBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="5"
                        SnapsToDevicePixels="True">

                        <ScrollViewer
                            x:Name="PART_ContentHost"
                            Margin="{TemplateBinding Padding}"
                            VerticalAlignment="Center" />
                    </Border>

                    <!-- ============================================= -->
                    <!--                    TRIGGERS                   -->
                    <!-- ============================================= -->

                    <ControlTemplate.Triggers>
                        <!-- FOCUS -->
                        <Trigger Property="IsKeyboardFocused"
                                 Value="True">

                            <Setter TargetName="TextBoxBorder"
                                    Property="BorderBrush"
                                    Value="{DynamicResource PrimaryBrush}" />

                            <Setter TargetName="TextBoxBorder"
                                    Property="BorderThickness"
                                    Value="2" />
                        </Trigger>


                        <!-- HOVER -->
                        <Trigger Property="IsMouseOver"
                                 Value="True">

                            <Setter TargetName="TextBoxBorder"
                                    Property="BorderBrush"
                                    Value="{DynamicResource PrimaryHoverBrush}" />
                        </Trigger>


                        <!-- DESABILITADO -->
                        <Trigger Property="IsEnabled"
                                 Value="False">

                            <Setter Property="Background"
                                    Value="{DynamicResource BackgroundDisabledBrush}" />

                            <Setter Property="Foreground"
                                    Value="{DynamicResource TextDisabledBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ========================================================= -->
    <!--                    ERROR TEXTBOX                          -->
    <!-- ========================================================= -->
    <Style x:Key="TextBoxErrorStyle"
           TargetType="TextBox"
           BasedOn="{StaticResource TextBoxBaseStyle}">

        <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextDangerBrush}" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="TextBoxBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="5"
                            SnapsToDevicePixels="True">
                        <ScrollViewer
                            x:Name="PART_ContentHost"
                            Margin="{TemplateBinding Padding}"
                            VerticalAlignment="Center" />   
                    </Border>

                    <!-- TRIGGERS -->
                    <ControlTemplate.Triggers>
                        <!-- FOCUS -->
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="TextBoxBorder" Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
                            <Setter TargetName="TextBoxBorder" Property="BorderThickness" Value="2" />
                        </Trigger>
                        
                        <!-- HOVER -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="TextBoxBorder" Property="BorderBrush" Value="{DynamicResource DangerHoverBrush}" />
                        </Trigger>

                        <!-- DESABILITADO -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Background" Value="{DynamicResource BackgroundDisabledBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextDisabledBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ========================================================= -->
    <!--                    READONLY TEXTBOX                       -->
    <!-- ========================================================= -->
    <Style x:Key="TextBoxReadOnlyStyle"
           TargetType="TextBox"
           BasedOn="{StaticResource TextBoxBaseStyle}">

        <Setter Property="IsReadOnly" Value="True" />
        <Setter Property="Background" Value="{DynamicResource BackgroundPanelBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BackgroundPanelBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
    </Style>

    <!-- ========================================================= -->
    <!--                   PASSWORD BOX STYLE                      -->
    <!-- ========================================================= -->
    <Style x:Key="PasswordBoxBaseStyle"
           TargetType="PasswordBox">

        <!-- APARÊNCIA -->
        <Setter Property="Background" Value="{DynamicResource BackgroundCardBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="5,2,5,2" />
        <Setter Property="MinHeight" Value="25" />

        <!-- TIPOGRAFIA -->
        <Setter Property="FontFamily" Value="{DynamicResource FontFamilyDefault}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeNormal}" />

        <!-- TEMPLATE -->
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="PasswordBox">
                    <Border
                        x:Name="PasswordBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="5">

                        <ScrollViewer
                            x:Name="PART_ContentHost"
                            Margin="{TemplateBinding Padding}" />
                    </Border>

                    <!-- TRIGGERS -->
                    <ControlTemplate.Triggers>

                        <Trigger Property="IsKeyboardFocused"
                                 Value="True">

                            <Setter TargetName="PasswordBorder"
                                    Property="BorderBrush"
                                    Value="{DynamicResource PrimaryBrush}" />

                            <Setter TargetName="PasswordBorder"
                                    Property="BorderThickness"
                                    Value="2" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>