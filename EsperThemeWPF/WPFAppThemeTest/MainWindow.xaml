<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
    xmlns:av="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="av"
    x:Class="WPFAppThemeTest.MainWindow" 
    Height="550" Width="800"
    Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Column="0" Margin="5,5,5,5" VerticalAlignment="Stretch">
            <Border Style="{DynamicResource BorderStyle}" Margin="5,5,5,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <Button Content="Botão Base"  Style="{DynamicResource ButtonBaseStyle}" Margin="5"/>
                        <Button Content="Botão Primário"  Style="{DynamicResource ButtonPrimaryStyle}" Margin="5"/>
                        <Button Content="Botão Secundário"  Style="{DynamicResource ButtonSecondaryStyle}" Margin="5"/>
                        <Button Content="Botão Terciário"  Style="{DynamicResource ButtonTertiaryStyle}" Margin="5"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <Button Content="Botão Sucesso"  Style="{DynamicResource ButtonSuccessStyle}" Margin="5"/>
                        <Button Content="Botão Alerta"  Style="{DynamicResource ButtonAlertStyle}" Margin="5"/>
                        <Button Content="Botão Perigo/Erro"  Style="{DynamicResource ButtonErrorStyle}" Margin="5"/>
                        <Button Content="Botão Ajuda/Info"  Style="{DynamicResource ButtonInfoStyle}" Margin="5"/>
                    </StackPanel>
                </Grid>
            </Border>
            <Border Style="{DynamicResource BorderStyle}" Margin="5,5,5,5" Grid.Row="6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <GroupBox Header="GroupBox - TextBlock" Style="{DynamicResource GroupBoxBaseStyle}" Grid.Column="0" Margin="0,0,2,0" VerticalAlignment="Stretch">
                        <StackPanel>
                            <TextBlock Text="Título 1" Style="{StaticResource TextBlockTitleStyle}" />
                            <TextBlock Text="Título 2" Style="{StaticResource TextBlockTitle2Style}" />
                            <TextBlock Text="Título 3" Style="{StaticResource TextBlockTitle3Style}" />
                            <TextBlock Text="Texto Corpo" Style="{StaticResource TextBlockBodyStyle}" />
                            <TextBlock Text="Texto Pequeno" Style="{StaticResource TextBlockSmallStyle}" />
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="GroupBox - TextBox" Style="{DynamicResource GroupBoxBaseStyle}" Grid.Column="1" Margin="2,0,0,0">
                        <StackPanel>
                            <TextBox Style="{DynamicResource TextBoxBaseStyle}" TextWrapping="Wrap" Text="TextBox Base" Margin="2"/>
                            <TextBox Style="{DynamicResource TextBoxErrorStyle}" TextWrapping="Wrap" Text="TextBox Erro" Margin="2"/>
                            <TextBox Style="{DynamicResource TextBoxReadOnlyStyle}" TextWrapping="Wrap" Text="TextBox Somente Leitura" Margin="2"/>
                            <TextBlock Text="Senha:" Style="{DynamicResource TextBlockSmallStyle}" Margin="2"/>
                            <PasswordBox Style="{DynamicResource PasswordBoxBaseStyle}" Margin="0"/>
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </Border>
        </StackPanel>
        <StackPanel Grid.Column="1" Margin="5,5,5,5">
            <Border Style="{DynamicResource BorderStyle}" Margin="5,5,5,5">
                <DataGrid x:Name="dgProdutos" Margin="5" AutoGenerateColumns="False" VerticalAlignment="Stretch" Style="{StaticResource DataGridDefaultStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Código" Binding="{Binding Codigo}"/>
                        <DataGridTextColumn Header="Descrição" Binding="{Binding Descricao}"/>
                        <DataGridTextColumn Header="Qtd" Binding="{Binding Quantidade}"/>
                        <DataGridTemplateColumn Header=" ">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Click="EditarProduto_Click" Tag="{Binding}" Style="{DynamicResource ButtonDataGridEditStyle}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header=" ">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Click="EditarProduto_Click" Tag="{Binding}" Style="{DynamicResource ButtonDataGridDeleteStyle}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
            <Border Style="{DynamicResource BorderStyle}" Margin="5,5,5,5">
                <StackPanel>
                    <ComboBox Style="{DynamicResource ComboBoxDefaultStyle}" ItemContainerStyle="{DynamicResource ComboBoxItemDefaultStyle}">
                        <ComboBoxItem Content="Item 1" />
                        <ComboBoxItem Content="Item 2" />
                        <ComboBoxItem Content="Item 3" />
                    </ComboBox>
                    <Border Style="{DynamicResource BorderErrorStyle}" Background="{DynamicResource DangerHover2Brush}">
                        <TextBlock Text="Erro desconhecido ao executar a tarefa!" FontWeight="Bold" FontSize="{DynamicResource FontSizeNormal}" HorizontalAlignment="Center" Style="{DynamicResource ErrorTextStyle}" />
                    </Border>
                    <TabControl Style="{DynamicResource DefaultTabControlStyle}">
                        <TabItem Header="CheckBoxes" Style="{DynamicResource DefaultTabItemStyle}">
                            <StackPanel>
                                <CheckBox Content="Check 1" Style="{DynamicResource CheckBoxDefaultStyle}"/>
                                <CheckBox Content="Check 2" Style="{DynamicResource CheckBoxDefaultStyle}"/>
                                <CheckBox Content="Check 3" Style="{DynamicResource CheckBoxDefaultStyle}"/>
                            </StackPanel>
                        </TabItem>
                        <TabItem Header="RadioButtons" Style="{DynamicResource DefaultTabItemStyle}" >
                            <StackPanel>
                                <RadioButton Content="Radio 1" GroupName="Grupo1" Style="{DynamicResource RadioButtonDefaultStyle}" />
                                <RadioButton Content="Radio 2" GroupName="Grupo1" Style="{DynamicResource RadioButtonDefaultStyle}"/>
                                <RadioButton Content="Radio 3" GroupName="Grupo1" Style="{DynamicResource RadioButtonDefaultStyle}"/>
                            </StackPanel>
                        </TabItem>
                    </TabControl>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource LoadingOverlayStyle}" Margin="5,5,5,5">
                <StackPanel HorizontalAlignment="Center" >
                    <Ellipse Style="{DynamicResource LoadingSpinnerStyle}"/>
                    <TextBlock Text="Carregando..." Style="{DynamicResource TextBlockDefaultStyle}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>

</Window>